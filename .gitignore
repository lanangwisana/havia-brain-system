# Composer vendor directories
vendor/
**/vendor/

# Writable directory (logs, cache, sessions, etc.)
writable/logs/*
writable/cache/*
writable/session/*
writable/debugbar/*
!writable/logs/.gitkeep
!writable/cache/.gitkeep
!writable/session/.gitkeep

# Environment file
.env

# IDE / Editor files
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Compiled files
*.map
